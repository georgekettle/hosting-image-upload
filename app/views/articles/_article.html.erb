<div id="<%= dom_id article %>">
  <% if false %>
    <% if article.photo.attached? %>
      <%= cl_image_tag article.photo.key, height: 300, width: 300, crop: :fill %>
      <div class="card-category"
          style="height: 300px; background-image: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('<%= cl_image_path article.photo.key, height: 300, crop: :fill %>')"
        >
          Cool article
        </div>
    <% else %>
      <%= image_tag 'default_img.png', width: 300 %>
    <% end %>
  <% end %>


  <% if article.photos.empty? %>
    <%= image_tag 'default_img.png', width: 300 %>
  <% else %>
    <% article.photos.each do |photo| %>
      <%= cl_image_tag photo.key, height: 300, width: 400, crop: :fill %>
    <% end %>
  <% end %>

  <p>
    <strong>Title:</strong>
    <%= article.title %>
  </p>

  <p>
    <strong>Body:</strong>
    <%= article.body %>
  </p>

</div>
